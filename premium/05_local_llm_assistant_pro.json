      "typeVersion": 4,
      "position": [
        700,
        260
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "url": "http://localhost:11434/api/generate",
        "method": "POST",
        "jsonParameters": true,
        "bodyParametersJson": "={\"model\":\"{{$json.local_model}}\",\"prompt\":\"Answer as a private ops assistant. Query: {{$json.user_query}}\",\"stream\":false}"
      },
      "id": "generate",
      "name": "Content Generation - Local Model Response",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        940,
        260
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2500
    },
    {
      "parameters": {
        "operation": "chat",
        "model": "gpt-4.1-mini",
        "messages": {
          "messageValues": [
            {
              "message": "=Evaluate this local-LLM output for SEO/AEO visibility around keyword local llm. Return strict JSON {seo_score, aeo_score, growth_projection, improvements[]}. Output: {{$json.response || $json}}"
            }
          ]
        }
      },
      "id": "scoring",
      "name": "Scoring - SEO/AEO/Growth",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [
        1180,
        260
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000,
      "credentials": {
        "openAiApi": {
          "id": "env-openai",
          "name": "OPENAI_API_KEY via {{$env.OPENAI_API_KEY}}"
        }
      }
    },
    {
      "parameters": {
        "mode": "jsonOutput",
        "jsonOutput": "={\"channel\":\"private_ops\",\"tier\":\"premium\",\"assistant_output\":$json,\"exports\":[\"json\",\"markdown\"]}"
      },
      "id": "exports",
      "name": "Publish/Export Payload",
      "type": "n8n-nodes-base.set",
      "typeVersion": 2,
      "position": [
        1420,
        260
      ]
    },
    {
      "parameters": {
        "mode": "jsonOutput",
        "jsonOutput": "={\"status\":\"ok\",\"workflow\":\"Local LLM Assistant Pro\",\"timestamp\":\"{{$now}}\"}"
      },
      "id": "logSuccess",
      "name": "Logging - Success",
      "type": "n8n-nodes-base.set",
      "typeVersion": 2,
