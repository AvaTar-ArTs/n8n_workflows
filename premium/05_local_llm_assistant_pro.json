        260
      ]
    },
    {
      "parameters": {
        "url": "http://localhost:11434/api/embeddings",
        "method": "POST",
        "jsonParameters": true,
        "bodyParametersJson": "={\"model\":\"nomic-embed-text\",\"prompt\":\"{{$json.user_query}}\"}"
      },
      "id": "embed",
      "name": "Enrichment - Local Embeddings",
